{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    "rootDir": "./typescript/",
    "outDir": "./javascript/",

    "target": "ES2015",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Style Options
    "noImplicitReturns": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,

    // Recommended Options
    "strict": true,
    "jsx": "react-jsx",

    // "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "module": "node16",
    "moduleResolution": "node16",
    "types": ["node", "jest"],
  },

  // "include": ["pkg/*"],

  "files": [
    "typescript/html.ts",
    "typescript/log.ts",
    "typescript/animate.ts",
    "typescript/mouse.ts",
    "typescript/tabs.ts",
    "typescript/storage.ts",
    "typescript/web_gl.ts",
    "typescript/web_gl_bezier.ts",
    "typescript/web_gl_flat.ts",
    "typescript/web_gl_3d_obj.ts",
    "typescript/web_gl_pt_field.ts",
    "typescript/wasm_memory.ts",

    "typescript/wasm_quat.ts",
    "typescript/wasm_vec.ts",
    "typescript/wasm_mat.ts",
    "typescript/wasm_transform.ts",

    "typescript/vector.ts",
    "typescript/quaternion.ts",

    "typescript/wasm_pkg.ts",

    "typescript/wasm_pkg_vec.test.ts",
  ],
}
